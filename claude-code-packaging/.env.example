# WonderFence credentials (required)
WONDERFENCE_API_KEY=your_wonderfence_api_key_here
WONDERFENCE_APP_ID=your_app_id_here

# AWS region for Bedrock (default: us-west-2)
AWS_REGION=us-west-2

# Optional WonderFence streaming behavior
# WONDERFENCE_STREAM_BUFFER_REPLACEMENTS=false
# WONDERFENCE_STREAM_BUFFER_EVAL=false

# Override the messages dump dir (default: ~/.alice-litellm/messages)
# WONDERFENCE_MESSAGES_DIR=
