# Upstream LLM provider — set by install.sh; override per-run via
# ./start.sh --bedrock | --anthropic
PROVIDER=bedrock

# WonderFence credentials (required for both providers)
WONDERFENCE_API_KEY=your_wonderfence_api_key_here
WONDERFENCE_APP_ID=your_app_id_here

# --- Bedrock provider -----------------------------------------------------
AWS_REGION=us-west-2

# --- Anthropic provider ---------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Optional ------------------------------------------------------------
# WONDERFENCE_STREAM_BUFFER_REPLACEMENTS=false
# WONDERFENCE_STREAM_BUFFER_EVAL=false
# WONDERFENCE_MESSAGES_DIR=
# Buffer/section size sent to WonderFence (request + streaming response).
# WONDERFENCE_BUFFER_BYTES=10000
# Streaming response: min bytes added before firing another eval.
# WONDERFENCE_EVAL_BYTES_INCREMENT=200
# Non-streaming response: byte overlap between consecutive 10K sections.
# WONDERFENCE_RESPONSE_SECTION_OVERLAP_BYTES=100
